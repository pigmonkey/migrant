# VM identity
VM_NAME="test-udp-host-port"
OS_VARIANT="debian13"

# Resources
RAM_MB=2048
VCPUS=2
DISK_GB=10

# Base image
IMAGE_URL="https://cloud.debian.org/images/cloud/trixie/latest/debian-13-generic-amd64.qcow2"
BOOT_FIRMWARE=uefi

# Network
NETWORKS=(
  "network=migrant"
)

# Host access — allow VM to reach host UDP port 9999
HOST_ACCESS=(
  "allow-host-port udp/9999"
)
