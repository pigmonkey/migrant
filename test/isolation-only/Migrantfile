# Pure network isolation test — no HOST_ACCESS exceptions.
# The VM should have NO access to the host or LAN; all outbound
# connections from the guest to the gateway must be blocked.

# VM identity
VM_NAME="test-isolation-only"
OS_VARIANT="debian13"

# Resources
RAM_MB=2048
VCPUS=2
DISK_GB=10

# Base image
IMAGE_URL="https://cloud.debian.org/images/cloud/trixie/latest/debian-13-generic-amd64.qcow2"
BOOT_FIRMWARE=uefi

# Network
NETWORKS=(
  "network=migrant"
)
