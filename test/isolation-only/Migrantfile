# Pure network isolation test — no HOST_ACCESS exceptions.
# The VM should have NO access to the host or LAN; all outbound
# connections from the guest to the gateway must be blocked.

# VM identity
VM_NAME="test-isolation-only"
OS_VARIANT="archlinux"

# Resources
RAM_MB=2048
VCPUS=2
DISK_GB=10

# Base image
IMAGE_URL="https://geo.mirror.pkgbuild.com/images/latest/Arch-Linux-x86_64-cloudimg.qcow2"

# Network
NETWORKS=(
  "network=migrant"
)
