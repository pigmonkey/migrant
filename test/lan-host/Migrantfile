# VM identity
VM_NAME="test-lan-host"
OS_VARIANT="debian13"

# Resources
RAM_MB=2048
VCPUS=2
DISK_GB=10

# Base image
IMAGE_URL="https://cloud.debian.org/images/cloud/trixie/latest/debian-13-generic-amd64.qcow2"
BOOT_FIRMWARE=uefi

# Network
NETWORKS=(
  "network=migrant"
)

# Host access rules — allow the VM to reach the default router
DEFAULT_ROUTER=$(ip route show default | awk '{print $3; exit}')
HOST_ACCESS=(
  "allow-lan-host $DEFAULT_ROUTER"
)
