# Test: network isolation disabled (NETWORK_ISOLATION=false)
# Verifies that with isolation off, the VM can reach the host/gateway freely.

# VM identity
VM_NAME="test-no-isolation"
OS_VARIANT="debian13"

# Resources
RAM_MB=2048
VCPUS=2
DISK_GB=10

# Base image
IMAGE_URL="https://cloud.debian.org/images/cloud/trixie/latest/debian-13-generic-amd64.qcow2"
BOOT_FIRMWARE=uefi

# Network
NETWORKS=(
  "network=migrant"
)

# Disable network isolation — VM should have unrestricted network access
NETWORK_ISOLATION=false
